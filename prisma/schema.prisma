  updatedAt DateTime @updatedAt
}

model SalesInvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String?
  customName  String?
  description String? @db.Text
  unit        String?
  quantity    Int
  unitPrice   Float   @default(0)
  taxRate     Float   @default(0)
  taxAmount   Float   @default(0)
  totalPrice  Float   @default(0)

  invoice SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model SalesInvoiceNote {
  id         String   @id @default(cuid())
  invoiceId  String
  userId     String
  content    String   @db.Text
  attachment String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  invoice SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id])
}

model SalesInvoiceActivityLog {
  id        String   @id @default(cuid())
  invoiceId String
  userId    String
  action    String // e.g. "CREATED", "UPDATED", "STATUS_CHANGED", "APPROVED"
  details   String?  @db.Text
  createdAt DateTime @default(now())

  invoice SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id])
}

model SalesPayment {
  id            String   @id @default(cuid())
  code          String   @unique
  date          DateTime @default(now())
  status        String   @default("COMPLETED") // COMPLETED, CANCELLED
  amount        Float
  paymentMethod String   @default("CASH") // CASH, BANK_TRANSFER
  reference     String?
  notes         String?  @db.Text
  attachment    String?  @db.Text

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  creatorId String
  creator   User   @relation("SalesPaymentCreator", fields: [creatorId], references: [id])

  allocations SalesPaymentAllocation[]
  tasks       Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SalesPaymentAllocation {
  id        String @id @default(cuid())
  paymentId String
  invoiceId String
  amount    Float

  payment SalesPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([paymentId, invoiceId])
}

model Todo {
  id        String   @id @default(cuid())
  text      String
  completed Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- EXPENSE MANAGEMENT MODULE ---

model ExpenseCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?   @db.Text
  expenses    Expense[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Expense {
  id            String   @id @default(cuid())
  code          String   @unique // e.g. EXP-202310-001
  date          DateTime @default(now())
  amount        Float
  payee         String? // Đối tượng nhận chi
  description   String   @db.Text
  paymentMethod String   @default("CASH") // CASH, BANK_TRANSFER, CREDIT_CARD
  status        String   @default("COMPLETED") // PENDING, COMPLETED, CANCELLED
  reference     String? // Receipt number or transaction ID
  attachment    String?  @db.Text // JSON string or URL

  categoryId String
  category   ExpenseCategory @relation(fields: [categoryId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  creatorId String
  creator   User   @relation("ExpenseCreator", fields: [creatorId], references: [id])

  tasks        Task[]
  notes        ExpenseNote[]
  activityLogs ExpenseActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExpenseNote {
  id         String   @id @default(cuid())
  expenseId  String
  userId     String
  content    String   @db.Text
  attachment String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
}

model ExpenseActivityLog {
  id        String   @id @default(cuid())
  expenseId String
  userId    String
  action    String // e.g. "CREATED", "UPDATED", "STATUS_CHANGED", "APPROVED"
  details   String?  @db.Text
  createdAt DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
}

// --- LEAD MANAGEMENT MODULE ---

model Lead {
  id   String @id @default(cuid())
  code String @unique // Mã cơ hội, dạng LEAD-YYMM-XXXX
  name String // Tên cơ hội (VD: "Lắp đặt hệ thống Camera nhà xưởng A")

  // Thông tin liên hệ (Dành cho Lead MỚI chưa là Khách Hàng)
  company     String? // Tên khách hàng / Công ty mới
  contactName String? // Người liên hệ chính mới
  email       String? @unique
  phone       String?

  // Liên kết với Khách Hàng HIỆN TẠI (Nếu là cơ hội từ KH cũ bán thêm)
  // HOẶC liên kết sau khi chuyển đổi Lead Mới thành Khách hàng chính thức
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  source       String? // Nguồn khách hàng dạng Text (lưu lại cho tương thích ngược)
  sourceId     String?
  sourceEntity LeadSource? @relation(fields: [sourceId], references: [id])

  status String @default("NEW") // Trạng thái Kanban: NEW, CONTACTED, QUALIFIED, PROPOSAL, WON, LOST

  estimatedValue    Float?    @default(0) // Giá trị ước tính
  expectedCloseDate DateTime? // Ngày dự kiến chốt hợp đồng/đơn hàng
  notes             String?   @db.Text

  // Người phụ trách
  assignedToId String?
  assignedTo   User?   @relation("LeadAssignee", fields: [assignedToId], references: [id])

  // Danh sách Người phụ trách chung (nhiều người)
  assignees LeadAssignee[]

  // Thảo luận/Bình luận & Ghi chú
  comments  LeadComment[]
  leadNotes LeadNote[]

  // Người tạo
  creatorId String?
  creator   User?   @relation("LeadCreator", fields: [creatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activityLogs   LeadActivityLog[]
  tasks          Task[] // Công việc liên quan (gọi điện, hẹn gặp...)
  EmailLog       EmailLog[]
  salesEstimates SalesEstimate[]
}

model LeadNote {
  id         String   @id @default(cuid())
  leadId     String
  userId     String
  content    String   @db.Text
  attachment String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

model LeadAssignee {
  leadId String
  userId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([leadId, userId])
}

model LeadComment {
  id      String @id @default(cuid())
  content String @db.LongText
  leadId  String
  userId  String
  lead    Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  parentId String?
  parent   LeadComment?  @relation("LeadCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  LeadComment[] @relation("LeadCommentReplies")

  reactions LeadCommentReaction[]

  images String? @db.LongText
  files  String? @db.LongText

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeadCommentReaction {
  id        String      @id @default(cuid())
  emoji     String
  commentId String
  userId    String
  comment   LeadComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([commentId, userId, emoji])
}

model LeadSource {
  id          String  @id @default(cuid())
  name        String  @unique
  description String? @db.Text
  isActive    Boolean @default(true)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  leads Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeadForm {
  id             String  @id @default(cuid())
  title          String // Tên nội bộ, ví dụ: "Form Landing Page Máy Lọc Nước"
  isActive       Boolean @default(true)
  source         String  @default("Website") // Nguồn khách hàng gán mặc định (Website, Zalo, Landing Page...)
  successMessage String? // Câu thông báo sau khi điền thành công

  assigneeId String? // ID Nhân viên mặc định sẽ được nhận/assigned cho Lead này
  assignee   User?   @relation("LeadFormAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeadActivityLog {
  id        String   @id @default(cuid())
  leadId    String
  userId    String
  action    String // VD: "TẠO_MỚI", "CHUYỂN_TRẠNG_THÁI", "THÊM_GHI_CHÚ"
  details   String?  @db.Text
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      String   @db.Text
  module    String?
  creatorId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator User @relation("EmailTemplateCreator", fields: [creatorId], references: [id])
}

model EmailLog {
  id      String @id @default(cuid())
  subject String
  body    String @db.Text
  toEmail String
  status  String @default("SENT") // SENT, OPENED, FAILED

  senderId   String?
  customerId String?
  estimateId String?
  invoiceId  String?
  leadId     String?

  trackingId String    @unique @default(cuid())
  openedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sender   User?          @relation("EmailSender", fields: [senderId], references: [id])
  customer Customer?      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  estimate SalesEstimate? @relation(fields: [estimateId], references: [id], onDelete: SetNull)
  invoice  SalesInvoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  lead     Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
}

// --- INTERNAL CHAT MODULE ---

model ChatRoom {
  id      String  @id @default(cuid())
  name    String? // Optional name for group chats
  isGroup Boolean @default(false)

  participants ChatParticipant[]
  messages     ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatParticipant {
  id       String   @id @default(cuid())
  roomId   String
  userId   String
  lastRead DateTime @default(now())

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roomId, userId])
}

model ChatMessage {
  id            String  @id @default(cuid())
  roomId        String
  senderId      String
  content       String  @db.Text
  attachmentUrl String? @db.Text

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// HR & ATTENDANCE MODULE
// ==========================================

model ShiftConfig {
  id             String  @id @default(cuid())
  name           String // Tên ca làm việc
  startTime      String  @default("08:00")
  endTime        String  @default("17:00")
  lunchStart     String  @default("12:00")
  lunchEnd       String  @default("13:00")
  lateThreshold  Int     @default(0) // Số phút cho phép đi muộn
  earlyThreshold Int     @default(0) // Số phút cho phép về sớm
  isActive       Boolean @default(true)

  users User[] @relation("UserShiftConfig")
}

model AttendanceRecord {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("UserAttendance", fields: [userId], references: [id], onDelete: Cascade)

  date DateTime @db.Date // Ngày chấm công (chỉ lấy phần ngày, ko lấy giờ)

  checkInTime     DateTime?
  checkInPhotoUrl String?   @db.LongText
  checkInLocation String?

  checkOutTime     DateTime?
  checkOutPhotoUrl String?   @db.LongText
  checkOutLocation String?

  status String  @default("PRESENT") // PRESENT, LATE, HALF_DAY, ABSENT
  notes  String?

  totalWorkMinutes Int? // Tính bằng phút

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date]) // Mỗi nhân viên chỉ có 1 bản ghi chấm công mỗi ngày
}

model LeaveRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserLeaveRequests", fields: [userId], references: [id])
  type      String // SICK_LEAVE, ANNUAL_LEAVE, UNPAID_LEAVE
  startDate DateTime
  endDate   DateTime
  reason    String
  imageUrl  String?  @db.LongText
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED

  approverId   String?
  approver     User?   @relation("ApprovedLeaveRequests", fields: [approverId], references: [id])
  approverNote String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// LIBRARY & TRAINING (KNOWLEDGE BASE) MODULE
// ==========================================

model DocumentCategory {
  id          String             @id @default(cuid())
  name        String
  description String?            @db.Text
  parentId    String?
  parent      DocumentCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children    DocumentCategory[] @relation("CategoryHierarchy")

  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id          String  @id @default(cuid())
  title       String
  description String? @db.Text
  fileUrl     String? @db.Text
  fileType    String? // PDF, MP4, LINK, DOCX, v.v.
  thumbnail   String? @db.Text // Ảnh bìa (bắt buộc với video)
  size        Int? // Kích thước byte
  isPublic    Boolean @default(true) // true: Ai cũng xem được

  categoryId String?
  category   DocumentCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  creatorId String
  creator   User   @relation("DocumentCreator", fields: [creatorId], references: [id])

  comments DocumentComment[]
  notes    DocumentNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocumentComment {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("DocumentCommenter", fields: [userId], references: [id])

  content String @db.Text

  parentId String?
  parent   DocumentComment?  @relation("DocumentCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  DocumentComment[] @relation("DocumentCommentReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocumentNote {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("DocumentNoter", fields: [userId], references: [id])

  content    String @db.Text // Ghi chú cá nhân (chỉ user đó xem được)
  pageNumber Int? // Lưu vết trang số mấy (nếu đọc PDF)
  videoTime  Int? // Lưu vết giây thứ mấy (nếu xem Video)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String?
  userAgent String?  @db.Text
  platform  String? // Thông tin OS/Browser sau khi phân tích
  loginAt   DateTime @default(now())

  user User @relation("UserLoginLogs", fields: [userId], references: [id], onDelete: Cascade)
}
