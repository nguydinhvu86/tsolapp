}

model SalesOrder {
  id     String   @id @default(cuid())
  code   String   @unique
  date   DateTime @default(now())
  status String   @default("DRAFT") // DRAFT, SENT, CONFIRMED, COMPLETED, CANCELLED
  notes  String?  @db.Text

  subTotal    Float @default(0)
  taxAmount   Float @default(0)
  totalAmount Float @default(0)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  creatorId String
  creator   User   @relation("SalesOrderCreator", fields: [creatorId], references: [id])

  items    SalesOrderItem[]
  invoices SalesInvoice[] // Invoices linked to this Sales Order
  tasks    Task[]

