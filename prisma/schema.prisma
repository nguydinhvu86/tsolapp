model SalesEstimateActivityLog {
  id         String   @id @default(cuid())
  estimateId String
  userId     String
  action     String // e.g., CREATED, STATUS_CHANGED
  details    String?  @db.Text
  createdAt  DateTime @default(now())

  estimate SalesEstimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
