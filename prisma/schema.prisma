datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model PermissionGroup {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  permissions String   @default("[]") @db.Text // JSON string of granted permissions for the group
  isSystem    Boolean  @default(false) // True for default groups (User, Manager, Admin)
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  password              String // Thêm trường mật khẩu đã mã hóa (hashed)
  name                  String?
  avatar                String? // Đường dẫn ảnh đại diện
  role                  String                 @default("USER") // ADMIN or USER
  permissions           String                 @default("[]") @db.Text // JSON string of granted permissions (legacy, to be deprecated or kept as overrides)
  permissionGroupId     String?
  permissionGroup       PermissionGroup?       @relation(fields: [permissionGroupId], references: [id])
  twoFactorSecret       String? // Khóa bí mật 2FA
  twoFactorEnabled      Boolean                @default(false) // Trạng thái 2FA
  createdTasks          Task[]                 @relation("TaskCreator")
  completedTasks        Task[]                 @relation("TaskCompleter")
  assignedTasks         TaskAssignee[]
  observedTasks         TaskObserver[]
  completedChecklists   TaskChecklist[]        @relation("ChecklistCompleter")
  taskActivityLogs      TaskActivityLog[]
  taskComments          TaskComment[]
  uploadedAttachments   TaskAttachment[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  TaskCommentReaction   TaskCommentReaction[]
  notifications         Notification[]
  inventoryTransactions InventoryTransaction[]
  purchaseRequisitions  PurchaseRequisition[]
  purchaseOrders        PurchaseOrder[] @relation("POCreator")
  purchaseBills         PurchaseBill[] @relation("BillCreator")
  purchasePayments      PurchasePayment[] @relation("PaymentCreator")
  
  salesEstimates        SalesEstimate[] @relation("EstimateCreator")
  salesOrders           SalesOrder[] @relation("SalesOrderCreator")
  salesInvoices         SalesInvoice[] @relation("SalesInvoiceCreator")
  salesPayments         SalesPayment[] @relation("SalesPaymentCreator")
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique // vd: COMPANY_NAME, COMPANY_LOGO
  value       String   @db.Text // Giá trị cấu hình
  description String?  @db.Text
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  link      String? // Optional path to redirect to (e.g. /tasks/123)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Customer {
  id              String           @id @default(cuid())
  name            String
  email           String?
  phone           String?
  address         String?
  taxCode         String?
  totalDebt       Float            @default(0) // Positive means they owe us money
  contracts       Contract[]
  quotes          Quote[]
  handovers       Handover[]
  paymentRequests PaymentRequest[]
  dispatches      Dispatch[]
  tasks           Task[]
  
  // Sales Relations
  salesEstimates  SalesEstimate[]
  salesOrders     SalesOrder[]
  salesInvoices   SalesInvoice[]
  salesPayments   SalesPayment[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model ContractTemplate {
  id          String     @id @default(cuid())
  name        String // e.g. Hợp đồng nguyên tắc, Hợp đồng đại lý
  description String?    @db.Text
  content     String     @db.LongText // The format string with placeholders
  editorType  String     @default("RICH_TEXT") // "RICH_TEXT" | "DRAG_DROP"
  contracts   Contract[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Contract {
  id         String             @id @default(cuid())
  title      String
  content    String             @db.LongText // The final generated content
  variables  String             @db.Text // JSON string storing the exact variables used
  status     String             @default("DRAFT") // DRAFT, SIGNED, CANCELLED
  customerId String
  templateId String
  customer   Customer           @relation(fields: [customerId], references: [id])
  template   ContractTemplate   @relation(fields: [templateId], references: [id])
  appendices ContractAppendix[]
  tasks      Task[]
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

model ContractAppendixTemplate {
  id          String             @id @default(cuid())
  name        String // e.g. Phụ lục thiết bị, Phụ lục gia hạn
  description String?            @db.Text
  content     String             @db.LongText // The format string with placeholders
  editorType  String             @default("RICH_TEXT") // "RICH_TEXT" | "DRAG_DROP"
  appendices  ContractAppendix[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model ContractAppendix {
  id         String                   @id @default(cuid())
  title      String
  content    String                   @db.LongText // The final generated content
  variables  String                   @db.Text // JSON string storing the exact variables used
  status     String                   @default("DRAFT") // DRAFT, SIGNED, CANCELLED
  contractId String
  templateId String
  contract   Contract                 @relation(fields: [contractId], references: [id], onDelete: Cascade)
  template   ContractAppendixTemplate @relation(fields: [templateId], references: [id])
  tasks      Task[]
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
}

model QuoteTemplate {
  id          String   @id @default(cuid())
  name        String // e.g. Báo giá lắp đặt Camera, Báo giá dịch vụ
  description String?  @db.Text
  content     String   @db.LongText // The format string with placeholders and Mini-Excel tables
  editorType  String   @default("RICH_TEXT") // "RICH_TEXT" | "DRAG_DROP"
  quotes      Quote[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Quote {
  id         String        @id @default(cuid())
  title      String
  content    String        @db.LongText // The final generated content
  variables  String        @db.Text // JSON string storing the exact variables used
  status     String        @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED
  customerId String
  templateId String
  customer   Customer      @relation(fields: [customerId], references: [id])
  template   QuoteTemplate @relation(fields: [templateId], references: [id])
  tasks      Task[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model HandoverTemplate {
  id          String     @id @default(cuid())
  name        String // e.g. Biên bản bàn giao thiết bị
  description String?    @db.Text
  content     String     @db.LongText
  editorType  String     @default("RICH_TEXT") // "RICH_TEXT" | "DRAG_DROP"
  handovers   Handover[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Handover {
  id         String           @id @default(cuid())
  title      String
  content    String           @db.LongText
  variables  String           @db.Text
  status     String           @default("DRAFT")
  customerId String
  templateId String
  customer   Customer         @relation(fields: [customerId], references: [id])
  template   HandoverTemplate @relation(fields: [templateId], references: [id])
  tasks      Task[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

model PaymentRequestTemplate {
  id              String           @id @default(cuid())
  name            String // e.g. Đề nghị thanh toán lần 1
  description     String?          @db.Text
  content         String           @db.LongText
  editorType      String           @default("RICH_TEXT") // "RICH_TEXT" | "DRAG_DROP"
  paymentRequests PaymentRequest[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model PaymentRequest {
  id         String                 @id @default(cuid())
  title      String
  content    String                 @db.LongText
  variables  String                 @db.Text
  status     String                 @default("DRAFT")
  customerId String
  templateId String
  customer   Customer               @relation(fields: [customerId], references: [id])
  template   PaymentRequestTemplate @relation(fields: [templateId], references: [id])
  tasks      Task[]
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
}

model DispatchTemplate {
  id          String     @id @default(cuid())
  name        String // e.g. Công văn nhắc nợ, Thông báo nghỉ lễ
  description String?    @db.Text
  content     String     @db.LongText // The format string with placeholders
  editorType  String     @default("RICH_TEXT") // "RICH_TEXT" | "DRAG_DROP"
  dispatches  Dispatch[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Dispatch {
  id         String           @id @default(cuid())
  title      String
  content    String           @db.LongText // The final generated content
  variables  String           @db.Text // JSON string storing the exact variables used
  status     String           @default("DRAFT") // DRAFT, SENT, CANCELLED
  customerId String
  templateId String
  customer   Customer         @relation(fields: [customerId], references: [id])
  template   DispatchTemplate @relation(fields: [templateId], references: [id])
  tasks      Task[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

// --- TASKS MODULE ---
model Task {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  status      String    @default("TODO") // TODO, IN_PROGRESS, REVIEW, DONE, CANCELLED
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  dueDate     DateTime?

  isRecurring    Boolean @default(false)
  recurrenceRule String? // vd: "DAILY", "WEEKLY", "MONTHLY"

  parentTaskId String?
  parentTask   Task?   @relation("TaskRecurrence", fields: [parentTaskId], references: [id])
  childTasks   Task[]  @relation("TaskRecurrence")

  assignees TaskAssignee[]

  creatorId String
  creator   User   @relation("TaskCreator", fields: [creatorId], references: [id])

  observers TaskObserver[]

  completedById String?
  completedBy   User?     @relation("TaskCompleter", fields: [completedById], references: [id])
  completedAt   DateTime?

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  contractId String?
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  quoteId String?
  quote   Quote?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  appendixId String?
  appendix   ContractAppendix? @relation(fields: [appendixId], references: [id], onDelete: SetNull)

  handoverId String?
  handover   Handover? @relation(fields: [handoverId], references: [id], onDelete: SetNull)

  paymentReqId String?
  paymentReq   PaymentRequest? @relation(fields: [paymentReqId], references: [id], onDelete: SetNull)

  dispatchId String?
  dispatch   Dispatch? @relation(fields: [dispatchId], references: [id], onDelete: SetNull)

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  purchaseBillId String?
  purchaseBill   PurchaseBill? @relation(fields: [purchaseBillId], references: [id], onDelete: SetNull)

  purchasePaymentId String?
  purchasePayment   PurchasePayment? @relation(fields: [purchasePaymentId], references: [id], onDelete: SetNull)

  salesEstimateId String?
  salesEstimate   SalesEstimate? @relation(fields: [salesEstimateId], references: [id], onDelete: SetNull)

  checklists   TaskChecklist[]
  comments     TaskComment[]
  attachments  TaskAttachment[]
  activityLogs TaskActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskAssignee {
  taskId String
  userId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
}

model TaskObserver {
  taskId String
  userId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
}

model TaskChecklist {
  id          String  @id @default(cuid())
  title       String
  isCompleted Boolean @default(false)

  completedById String?
  completedBy   User?     @relation("ChecklistCompleter", fields: [completedById], references: [id])
  completedAt   DateTime?

  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskActivityLog {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  details   String?  @db.Text
  createdAt DateTime @default(now())
}

model TaskComment {
  id      String @id @default(cuid())
  content String @db.Text
  taskId  String
  userId  String
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Nested Replies Support
  parentId String?
  parent   TaskComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  TaskComment[] @relation("CommentReplies")

  images String? @db.Text
  files  String? @db.Text

  reactions TaskCommentReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskCommentReaction {
  id        String      @id @default(cuid())
  commentId String
  userId    String
  emoji     String // e.g., 'like', 'heart', 'haha'
  comment   TaskComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([commentId, userId, emoji])
}

model TaskAttachment {
  id           String   @id @default(cuid())
  fileName     String
  fileUrl      String
  fileType     String
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
}

// --- INVENTORY MANAGEMENT MODULE ---

model Warehouse {
  id              String                 @id @default(cuid())
  name            String
  location        String?
  isDefault       Boolean                @default(false)
  inventories     Inventory[]
  transactionsOut InventoryTransaction[] @relation("WarehouseOut")
  transactionsIn  InventoryTransaction[] @relation("WarehouseIn")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
}

// Enums mapped to String for SQLite compatibility

model ProductGroup {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?   @db.Text
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id               String                     @id @default(cuid())
  sku              String                     @unique
  name             String
  type             String                     @default("PRODUCT") // "PRODUCT" | "SERVICE"
  unit             String                     @default("Cái")
  taxRate          Float                      @default(0) // Default VAT (%)
  importPrice      Float                      @default(0)
  salePrice        Float                      @default(0)
  description      String?                    @db.Text
  notes            String?                    @db.Text
  minStockLevel    Int                        @default(10)
  isActive         Boolean                    @default(true)
  groupId          String?
  group            ProductGroup?              @relation(fields: [groupId], references: [id])
  inventories      Inventory[]
  transactionItems InventoryTransactionItem[]
  
  supplierProducts          SupplierProduct[]
  purchaseRequisitionItems  PurchaseRequisitionItem[]
  purchaseOrderItems        PurchaseOrderItem[]
  purchaseBillItems         PurchaseBillItem[]
  
  salesEstimateItems        SalesEstimateItem[]
  salesOrderItems           SalesOrderItem[]
  salesInvoiceItems         SalesInvoiceItem[]

  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
}

model Inventory {
  id          String    @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Int       @default(0)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId])
}

// Enums mapped to String for SQLite compatibility

model InventoryTransaction {
  id              String   @id @default(cuid())
  code            String   @unique
  type            String // "IN" | "OUT" | "TRANSFER" | "ADJUSTMENT"
  status          String   @default("DRAFT") // "DRAFT" | "COMPLETED" | "CANCELLED"
  date            DateTime @default(now())
  notes           String?  @db.Text
  fromWarehouseId String?
  toWarehouseId   String?
  supplierId      String?

  fromWarehouse Warehouse? @relation("WarehouseOut", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse? @relation("WarehouseIn", fields: [toWarehouseId], references: [id])
  supplier      Supplier?  @relation(fields: [supplierId], references: [id])

  items InventoryTransactionItem[]

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryTransactionItem {
  id            String @id @default(cuid())
  transactionId String
  productId     String
  quantity      Int
  price         Float  @default(0)

  transaction InventoryTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product              @relation(fields: [productId], references: [id])
}

// --- PROCUREMENT & SUPPLIER MANAGEMENT MODULE ---

model Supplier {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  taxCode     String?
  website     String?
  businessType String?
  bankAccount String?
  bankName    String?
  notes       String?  @db.Text
  
  // Financials
  totalDebt   Float    @default(0) // Positive means we owe them money
  
  // Relations
  products    SupplierProduct[]
  orders      PurchaseOrder[]
  bills       PurchaseBill[]
  payments    PurchasePayment[]
  inventoryTx InventoryTransaction[] // IN transactions from this supplier
  tasks       Task[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SupplierProduct {
  id          String   @id @default(cuid())
  supplierId  String
  productId   String
  supplierSku String?
  price       Float    @default(0)
  
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([supplierId, productId])
}

model PurchaseRequisition {
  id          String   @id @default(cuid())
  code        String   @unique
  date        DateTime @default(now())
  status      String   @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, REJECTED
  notes       String?  @db.Text
  
  creatorId   String
  creator     User     @relation(fields: [creatorId], references: [id])
  
  items       PurchaseRequisitionItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PurchaseRequisitionItem {
  id            String   @id @default(cuid())
  requisitionId String
  productId     String
  quantity      Int
  notes         String?  @db.Text
  
  requisition   PurchaseRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  product       Product             @relation(fields: [productId], references: [id])
}

model PurchaseOrder {
  id          String   @id @default(cuid())
  code        String   @unique
  date        DateTime @default(now())
  status      String   @default("DRAFT") // DRAFT, SENT, PARTIAL_RECEIVED, COMPLETED, CANCELLED
  notes       String?  @db.Text
  
  subTotal    Float    @default(0)
  taxAmount   Float    @default(0)
  totalAmount Float    @default(0)
  
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  
  creatorId   String
  creator     User     @relation("POCreator", fields: [creatorId], references: [id])
  
  items       PurchaseOrderItem[]
  bills       PurchaseBill[] // Bills linked to this PO
  tasks       Task[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PurchaseOrderItem {
  id            String   @id @default(cuid())
  orderId       String
  productId     String
  quantity      Int
  unitPrice     Float    @default(0)
  taxRate       Float    @default(0)
  taxAmount     Float    @default(0)
  totalPrice    Float    @default(0)
  
  order         PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])
}

model PurchaseBill {
  id          String   @id @default(cuid())
  code        String   @unique // Internal Bill Code
  supplierInvoice String? // Supplier's physical invoice number
  date        DateTime @default(now())
  dueDate     DateTime? // Hạn thanh toán
  status      String   @default("DRAFT") // DRAFT, APPROVED (creates IN Tx & Debt), PARTIAL_PAID, PAID
  notes       String?  @db.Text
  attachment  String?  @db.Text // Chuỗi JSON chứa mảng tài liệu đính kèm
  
  subTotal    Float    @default(0)
  taxAmount   Float    @default(0)
  totalAmount Float    @default(0)
  paidAmount  Float    @default(0)
  
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  
  orderId     String?
  order       PurchaseOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  
  creatorId   String
  creator     User     @relation("BillCreator", fields: [creatorId], references: [id])
  
  items       PurchaseBillItem[]
  allocations PurchasePaymentAllocation[] // Payments allocated to this bill
  tasks       Task[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PurchaseBillItem {
  id            String   @id @default(cuid())
  billId        String
  productId     String
  quantity      Int
  unitPrice     Float    @default(0)
  taxRate       Float    @default(0)
  taxAmount     Float    @default(0)
  totalPrice    Float    @default(0)
  
  bill          PurchaseBill  @relation(fields: [billId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])
}

model PurchasePayment {
  id          String   @id @default(cuid())
  code        String   @unique
  date        DateTime @default(now())
  amount      Float
  paymentMethod String @default("CASH") // CASH, BANK_TRANSFER
  reference   String?  // Transaction ID
  notes       String?  @db.Text
  attachment  String?  @db.Text
  
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  
  creatorId   String
  creator     User     @relation("PaymentCreator", fields: [creatorId], references: [id])
  
  allocations PurchasePaymentAllocation[]
  tasks       Task[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PurchasePaymentAllocation {
  id          String   @id @default(cuid())
  paymentId   String
  billId      String
  amount      Float
  
  payment     PurchasePayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  bill        PurchaseBill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@unique([paymentId, billId])
}

// --- SALES MANAGEMENT MODULE ---

model SalesEstimate {
  id          String   @id @default(cuid())
  code        String   @unique
  date        DateTime @default(now())
  validUntil  DateTime?
  status      String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED
  notes       String?  @db.Text
  
  subTotal    Float    @default(0)
  taxAmount   Float    @default(0)
  totalAmount Float    @default(0)
  
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  
  creatorId   String
  creator     User     @relation("EstimateCreator", fields: [creatorId], references: [id])
  
  items       SalesEstimateItem[]
  tasks       Task[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SalesEstimateItem {
  id            String   @id @default(cuid())
  estimateId    String
  productId     String
  quantity      Int
  unitPrice     Float    @default(0)
  taxRate       Float    @default(0)
  taxAmount     Float    @default(0)
  totalPrice    Float    @default(0)
  
  estimate      SalesEstimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])
}

model SalesOrder {
  id          String   @id @default(cuid())
  code        String   @unique
  date        DateTime @default(now())
  status      String   @default("DRAFT") // DRAFT, SENT, CONFIRMED, COMPLETED, CANCELLED
  notes       String?  @db.Text
  
  subTotal    Float    @default(0)
  taxAmount   Float    @default(0)
  totalAmount Float    @default(0)
  
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  
  creatorId   String
  creator     User     @relation("SalesOrderCreator", fields: [creatorId], references: [id])
  
  items       SalesOrderItem[]
  invoices    SalesInvoice[] // Invoices linked to this Sales Order
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SalesOrderItem {
  id            String   @id @default(cuid())
  orderId       String
  productId     String
  quantity      Int
  unitPrice     Float    @default(0)
  taxRate       Float    @default(0)
  taxAmount     Float    @default(0)
  totalPrice    Float    @default(0)
  
  order         SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product    @relation(fields: [productId], references: [id])
}

model SalesInvoice {
  id          String   @id @default(cuid())
  code        String   @unique
  date        DateTime @default(now())
  dueDate     DateTime?
  status      String   @default("DRAFT") // DRAFT, ISSUED (creates OUT Tx & Debt), PARTIAL_PAID, PAID
  notes       String?  @db.Text
  attachment  String?  @db.Text
  
  subTotal    Float    @default(0)
  taxAmount   Float    @default(0)
  totalAmount Float    @default(0)
  paidAmount  Float    @default(0)
  
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  
  orderId     String?
  order       SalesOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  
  creatorId   String
  creator     User     @relation("SalesInvoiceCreator", fields: [creatorId], references: [id])
  
  items       SalesInvoiceItem[]
  allocations SalesPaymentAllocation[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SalesInvoiceItem {
  id            String   @id @default(cuid())
  invoiceId     String
  productId     String
  quantity      Int
  unitPrice     Float    @default(0)
  taxRate       Float    @default(0)
  taxAmount     Float    @default(0)
  totalPrice    Float    @default(0)
  
  invoice       SalesInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])
}

model SalesPayment {
  id          String   @id @default(cuid())
  code        String   @unique
  date        DateTime @default(now())
  amount      Float
  paymentMethod String @default("CASH") // CASH, BANK_TRANSFER
  reference   String?  
  notes       String?  @db.Text
  attachment  String?  @db.Text
  
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  
  creatorId   String
  creator     User     @relation("SalesPaymentCreator", fields: [creatorId], references: [id])
  
  allocations SalesPaymentAllocation[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SalesPaymentAllocation {
  id          String   @id @default(cuid())
  paymentId   String
  invoiceId   String
  amount      Float
  
  payment     SalesPayment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice     SalesInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@unique([paymentId, invoiceId])
}
