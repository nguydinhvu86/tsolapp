  updatedAt DateTime @updatedAt
}

model SalesOrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String?
  customName  String?
  description String? @db.Text
  unit        String?
  quantity    Int
  unitPrice   Float   @default(0)
  taxRate     Float   @default(0)
  taxAmount   Float   @default(0)
  totalPrice  Float   @default(0)

  order   SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model SalesInvoice {
  id         String    @id @default(cuid())
  code       String    @unique
  date       DateTime  @default(now())
  dueDate    DateTime?
  status     String    @default("DRAFT") // DRAFT, ISSUED (creates OUT Tx & Debt), PARTIAL_PAID, PAID
  notes      String?   @db.Text
  attachment String?   @db.Text
  tags       String? // Commas separated list of tags

  subTotal    Float @default(0)
  taxAmount   Float @default(0)
  totalAmount Float @default(0)
  paidAmount  Float @default(0)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  orderId String?
  order   SalesOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)

